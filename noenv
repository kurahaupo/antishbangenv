#!/bin/bash

shopt -s extglob

die() { local -i e=$1 ; printf >&2 '%s\n' "${*:2}" ; exit "$e" ; }

(( true = 0==0, false = !true ))

slurp=false
input=
output=

for ((;$#;)) do
    case $1 in
    --slurp)    slurp=true ;;
    --input=*)  input=${1#*=} ;;
    --output=*) output=${1#*=} ;;
    --*)        die 64 "Invalid option '$1'" ;;                         # EX_USAGE
    *)          break ;;
    esac
    shift
done

[[ $input  ]] || { input=$1  ; shift ; }
[[ $output ]] || { output=$1 ; shift ; }

(( $# == 0 )) || die 64 'Too many args'                                 # EX_USAGE

[[ $input  ]] || die 64 'Missing input arg 1'                           # EX_USAGE
[[ $output ]] || (( slurp )) || die 64 'Missing output arg 2'           # EX_USAGE

IFS= read -r raw_shbang < "$input" &&
[[ $raw_shbang = '#!'* ]] || die 65 'input does not start with #! line' # EX_DATAERR
shbang=${raw_shbang##'#!'*(' ')}
IFS=$' \t' read -r shbang shbangopts <<< "$shbang"
interp=${shbang##*/}

if (( verbose )) ; then
    printf >&2 'shbang=%s\n' "$shbang"
fi

if [[ $output = ?(-) ]]
then
    :   # stdout
elif (( slurp ))
then
    : "${output:=$input}"   # overwrite input if slurp and no output specified

    command -v slurp 2>/dev/null ||
    slurp() {
        local output="$2" # ignore -o
        local tmp=/tmp/slurp.$$.$RANDOM
        cat > "$tmp" &&
        cat < "$tmp" > "$output"
        rm -f "$tmp"
    }
    exec > >( slurp -o "$output" )
else
    [[ $input -ef $output ]] && die 65 'Input and output must not be the same file without --slurp'     # EX_DATAERR
    exec > "$output"
fi
chmod a+rx "$output"

preamble=\
'#!/bin/sh -e
{ {
printf "#!%s\n" $( command -v "INTERP" )"INTOPTS"
printf "##  %-54s ##\n" "" \
 "This self-installed script was generated by noenv at" \
 https://github.com/kurahaupo/antishbangenv "" ""
} |
dd of="$0" conv=notrunc bs=1 count=SIZE 2>/dev/null
exec "$0" "$@"
}   ####  Next line must be at byte offset BOFF  ####
'

preamble="${preamble/INTERP/$interp}"
preamble="${preamble/INTOPTS/${shbangopts:+ $shbangopts}}"

# "$size" replaces "SIZE" so make sure it's 4 bytes (including padding spaces)
printf -v boff '%-4u' ${#preamble}
printf -v size '%-4u' $((boff - 46))

preamble="${preamble//BOFF/$boff}"
preamble="${preamble//SIZE/$size}"

printf %s "$preamble"
tail -n+2 "$input"
